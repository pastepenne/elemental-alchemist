  m_Script: {fileID: 11500000, guid: 2cbaeec8dbe84e069925173ac3a6210b, type: 3}
  m_Name: Dlg_Underground_Guardian_Completed
  m_EditorClassIdentifier: Assembly-CSharp::ElementalAlchemist.Dialogue.DialogueData
  _speaker: Underground Guardian
  _lines:
  - The living turned to stone, yet never truly lost. You understand what endures here.
  - Take the Fragment of Flesh. Two now rest in your hands, and you grow harder to stop with each one you gather.
  - But weigh this in the dark. The more a hand can make, the more it can unmake. Never forget there is a difference.
