  m_Script: {fileID: 11500000, guid: 2cbaeec8dbe84e069925173ac3a6210b, type: 3}
  m_Name: Dlg_Underground_Guardian_Riddle
  m_EditorClassIdentifier: Assembly-CSharp::ElementalAlchemist.Dialogue.DialogueData
  _speaker: Underground Guardian
  _lines:
  - Welcome to the cradle of Flesh. Every creature that ever walked beneath the sun is gathered here, held in the patient dark, and the deep forgets nothing.
  - So answer me. Lay what the living leave behind into the cold grip of the mountain's grey body, and let the slow weight of ages press the two as one.
  - Name what the deep keeps long after the flesh is gone. Bring it to me, and the Fragment of Flesh is yours.
