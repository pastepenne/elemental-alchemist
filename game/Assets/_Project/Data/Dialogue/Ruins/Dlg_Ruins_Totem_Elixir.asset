  m_Script: {fileID: 11500000, guid: 2cbaeec8dbe84e069925173ac3a6210b, type: 3}
  m_Name: Dlg_Ruins_Totem_Elixir
  m_EditorClassIdentifier: Assembly-CSharp::ElementalAlchemist.Dialogue.DialogueData
  _speaker: Ancient Totem
  _lines:
  - A shallow basin crowns this totem, forever slick with a golden film that never dries.
  - Steep the living spark drawn from all that grows in the metal time can never dull, and you draw off the draught that holds death at the door.
