  m_Script: {fileID: 11500000, guid: 2cbaeec8dbe84e069925173ac3a6210b, type: 3}
  m_Name: Dlg_Ruins_Totem_Essence
  m_EditorClassIdentifier: Assembly-CSharp::ElementalAlchemist.Dialogue.DialogueData
  _speaker: Ancient Totem
  _lines:
  - This totem is wound with the carving of a flower long withered, yet the stone smells faintly of bloom.
  - Steep the meadow's bloom in the sea's bitter tears, and draw out the living spark that hides inside all that grows.
