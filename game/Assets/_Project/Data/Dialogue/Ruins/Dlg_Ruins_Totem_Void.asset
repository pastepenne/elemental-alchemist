  m_Script: {fileID: 11500000, guid: 2cbaeec8dbe84e069925173ac3a6210b, type: 3}
  m_Name: Dlg_Ruins_Totem_Void
  m_EditorClassIdentifier: Assembly-CSharp::ElementalAlchemist.Dialogue.DialogueData
  _speaker: Ancient Totem
  _lines:
  - This totem is cut from something darker than any stone, and cold pours off its surface.
  - Wed the breath of the heavens to the black glass the earth weeps in fire. Where they meet, nothing remains, and that nothing is a door.
