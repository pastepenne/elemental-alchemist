  m_Script: {fileID: 11500000, guid: 2cbaeec8dbe84e069925173ac3a6210b, type: 3}
  m_Name: Dlg_Tutorial_AfterWood
  m_EditorClassIdentifier: Assembly-CSharp::ElementalAlchemist.Dialogue.DialogueData
  _speaker: Grand Master
  _lines:
  - "Collecting those branches also helped you discover a new element \u2014 Wood. "
  - By pressing TAB you can look into your pouch to see what elements you have collected.
  - Tough you won't see the core elements, since they are always in your lab.
  - You can also read the tome, there you will find every element you discovered.
  - Now go throw the wood on the furnace.
